// carcare.mn — multi-tenant авто үйлчилгээний платформын schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Tenant ---------------------------------------------------------------

model Tenant {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String   @unique
  registerNumber String   @unique // 7 оронтой улсын бүртгэлийн дугаар (string-р хадгална)
  email          String   @unique
  phone1         String
  phone2         String?
  logoUrl        String?
  plan           Plan     @default(FREE)
  suspended      Boolean  @default(false) // super admin-аар түр зогсоосон эсэх
  acceptsOnlineBooking Boolean @default(false) // Онлайн цаг захиалгын каталогт харагдах эсэх
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users               User[]
  roles               Role[]
  branches            Branch[]
  customers           Customer[]
  vehicles            Vehicle[]
  services            Service[]
  serviceOrders       ServiceOrder[]
  diagnosticTemplates DiagnosticTemplate[]
  diagnosticReports   DiagnosticReport[]
  units               Unit[]
  laborCategories     LaborCategory[]
  subscriptions       Subscription[]
  subscriptionPayments SubscriptionPayment[]
  auditLogs           AuditLog[]
  qpaySettings        TenantQPaySettings?
  orderPayments       OrderPayment[]
  appointments        Appointment[]
  notifications       Notification[]
}

enum Plan {
  FREE
  BUSINESS
  ENTERPRISE
}

// --- User -----------------------------------------------------------------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  firstName    String // Нэр
  lastName     String // Овог
  // Канон 8 оронтой формат (lib/phone.ts). Бүх ажилтанд давхцахгүй (глобал).
  phone        String  @unique
  // Админ ажилтан үүсгэхэд нууц үг тавихгүй — ажилтан анх удаа нэвтрэхдээ
  // өөрөө үүсгэнэ (OTP-ээр). Тиймээс идэвхжих хүртэл null.
  passwordHash String?
  // Ажилтан утсаараа OTP авч нууц үгээ үүсгэж аккаунтаа идэвхжүүлсэн эсэх.
  // false бол паролиар нэвтэрч чадахгүй — эхлээд идэвхжүүлэх ёстой.
  verified Boolean @default(false)

  // Тенант бүртгүүлсэн админ. Бүх эрхтэй, ямар ч role-той эсэхээс үл хамаарна.
  // Үүрэг сольж болохгүй, устгахгүй (сүүлийн админыг үлдээх ёстой).
  isOwner Boolean @default(false)

  // Тенант доторх өөрийн үүсгэсэн Role-той холбоо. isOwner=true бол null байж болно.
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // Buffer-аас бус нэвтрэх алдааны тоо. 5 алдаа нэрсэн үед lockedAt тогтоосноор
  // нэвтрэх боломжгүй болж, нууц үгээ сэргээх замаар л сэргэдэг.
  failedLoginAttempts Int       @default(0)
  lockedAt            DateTime?

  // Гар идэвхгүй болгох flag. true бол ажилтан хэвийн ажиллана. Манагер цаг
  // үе гарваал false болгож login-г блоклож болно (бичлэг нь хадгалагдана).
  isActive    Boolean   @default(true)
  // Түр ажиллах ажилтан үүсгэх үед энэ огноо тогтооно. Энэ огнооноос хойш
  // нэвтрэх оролдлого хийвэл automatically блоклогдоно. null бол байнгын.
  activeUntil DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedOrders      ServiceOrder[]       @relation("AssignedTo")
  diagnosticTemplates DiagnosticTemplate[] @relation("DiagnosticTemplateCreatedBy")
  diagnosticReports   DiagnosticReport[]   @relation("DiagnosticReportFilledBy")
  refreshTokens       RefreshToken[]
  sessions            UserSession[]
  devices             Device[]
  notifications       Notification[]
  auditLogs           AuditLog[]           @relation("AuditLogActor")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, isOwner])
  @@index([roleId])
  @@index([activeUntil])
}

// --- Role (тенант бүрийн өөрийн үүсгэдэг хэрэглэгчийн үүрэг) -------------
// Админ (isOwner=true) бүртгэлийн дараа байгууллагынхаа онцлогт тохируулан
// Role үүсгэж, permission массивыг сонгоно. Ажилтан үүсгэх үед эдгээрээс
// сонгоно. OWNER үргэлж бүх эрхтэй, тусдаа Role үүсэхгүй.

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Permission code-уудын массив. Кодын жагсаалт нь `lib/auth/permissions.ts`
  // дотор төвлөрсөн (ж: "orders.manage", "audit.view").
  permissions String[]
  isActive    Boolean  @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
} 

// --- Branch ---------------------------------------------------------------

model Branch {
  id        String  @id @default(cuid())
  name      String
  phone     String?
  isPrimary Boolean @default(false) // Тенант тус бүрд нэг л үндсэн салбар байна

  // --- Хаяг ---
  city     String? // Хот / Аймаг (жишээ: "Улаанбаатар")
  district String? // Дүүрэг / Сум (жишээ: "Баянзүрх")
  khoroo   String? // Хороо / Баг (жишээ: "6-р хороо")
  address  String? // Дэлгэрэнгүй (гудамж, тоот, баримжаа)

  // --- Газарзүйн байршил ---
  latitude  Float?
  longitude Float?

  // --- Ажиллах цаг (default) ---
  // Өдөр тус бүрийн цагийг BranchSchedule дээр override хийж болно.
  openTime  String? // "HH:MM" (24 цагийн) — default
  closeTime String? // "HH:MM" (24 цагийн) — default

  // --- Онлайн цаг захиалгын slot тохиргоо ---
  slotMinutes  Int? // нэг цагийн нүхний урт (минут). null бол 30.
  slotCapacity Int? // нэг нүхэнд зэрэг авах захиалгын тоо. null бол 1.

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  serviceOrders     ServiceOrder[]
  diagnosticReports DiagnosticReport[]
  schedules         BranchSchedule[]
  auditLogs         AuditLog[]
  appointments      Appointment[]

  @@index([tenantId])
}

// --- BranchSchedule (Branch-ийн өдрийн ажиллах хуваарь) ------------------
// Тус салбарын долоо хоногийн өдөр тус бүрт нэг л бичлэг. Энэ нь Int[]
// талбараас илүү — өдөр тус бүрийн нээх/хаах цагийг тусад нь override хийх
// боломжтой, мөн "Ням гарагт ажилладаг бүх салбар" гэх мэт шүүлт хийхэд
// index-тэй.

enum Weekday {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model BranchSchedule {
  id        String  @id @default(cuid())
  weekday   Weekday
  isOpen    Boolean @default(false)
  openTime  String? // "HH:MM" — null бол branch-ийн default
  closeTime String? // "HH:MM" — null бол branch-ийн default

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, weekday])
  @@index([weekday, isOpen])
}

// --- Customer -------------------------------------------------------------

model Customer {
  id       String  @id @default(cuid())
  fullName String
  phone    String
  email    String?
  note     String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Онлайн цаг захиалгын global Account-той гүүр. null бол ажилтан гар аргаар
  // үүсгэсэн (аккаунтгүй) Customer. Тенант тус бүрд нэг Account-д нэг Customer.
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles          Vehicle[]
  serviceOrders     ServiceOrder[]
  diagnosticReports DiagnosticReport[]
  appointments      Appointment[]

  @@unique([tenantId, accountId])
  @@index([tenantId, phone])
}

// --- Vehicle --------------------------------------------------------------

model Vehicle {
  id            String  @id @default(cuid())
  plate         String
  vin           String?
  make          String
  model         String
  year          Int?
  mileage       Int?
  fuelType      String? // "Бензин", "Дизель", "Хийн", "Цахилгаан" гэх мэт (HUR-аас татна)
  wheelPosition String? // "Зүүн" / "Баруун" — жолооны хүрд аль талд (HUR-аас татна)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrders     ServiceOrder[]
  diagnosticReports DiagnosticReport[]
  appointments      Appointment[]

  @@unique([tenantId, plate])
  @@index([tenantId])
}

// --- ServiceOrder ---------------------------------------------------------

model ServiceOrder {
  id            String        @id @default(cuid())
  number        String
  status        OrderStatus   @default(SCHEDULED)
  paymentStatus PaymentStatus @default(UNPAID)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  paidAt        DateTime?
  notes         String?
  totalAmount   Decimal?      @db.Decimal(12, 2)
  paidAmount    Decimal?      @db.Decimal(12, 2)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  items               ServiceItem[]
  reports             DiagnosticReport[]
  plannedDiagnostics  OrderDiagnostic[]
  payments            OrderPayment[]
  appointment         Appointment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([branchId, scheduledAt])
}

enum OrderStatus {
  SCHEDULED
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// --- ServiceItem (line item) ----------------------------------------------

model ServiceItem {
  id          String   @id @default(cuid())
  kind        ItemKind
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)

  orderId String
  order   ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([serviceId])
}

enum ItemKind {
  LABOR
  DIAGNOSTIC
  PART
  FEE
}

// --- Service (Үйлчилгээ — Ажил/Оношилгоо/Сэлбэг-Бараа нэгдсэн каталог) ---

model Service {
  id          String      @id @default(cuid())
  type        ServiceKind
  name        String
  code        String?     // SKU/код — Бараанд хэрэглэх (заавал биш)
  price       Decimal     @db.Decimal(12, 2) // зарах үнэ
  costPrice   Decimal?    @db.Decimal(12, 2) // өртөг (зөвхөн GOODS)
  stock       Decimal?    @db.Decimal(12, 3) // нөөц (зөвхөн GOODS)
  description String?
  isActive    Boolean     @default(true)

  // Зарагдах хэмжих нэгж — LABOR/GOODS-д заавал (DB-д nullable, app дээр шалгана)
  unitId String?
  unit   Unit?   @relation("ServiceUnit", fields: [unitId], references: [id], onDelete: SetNull)

  // Ажил хийгдэх хугацаа (LABOR-д заавал биш) — утга + нэгж
  durationValue  Decimal? @db.Decimal(12, 3)
  durationUnitId String?
  durationUnit   Unit?    @relation("ServiceDurationUnit", fields: [durationUnitId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Ажлын ангилал (зөвхөн LABOR төрөлд хэрэглэнэ — DB-д nullable, app-level дээр LABOR үед заавал)
  laborCategoryId String?
  laborCategory   LaborCategory? @relation(fields: [laborCategoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ServiceItem[]

  @@unique([tenantId, type, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, name])
  @@index([laborCategoryId])
  @@index([unitId])
  @@index([durationUnitId])
}

enum ServiceKind {
  LABOR
  DIAGNOSTIC
  GOODS
}

// --- DiagnosticTemplate (тенант өөрөө зохиосон оношилгооны хуудас) --------

model DiagnosticTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        DiagnosticType
  schema      Json           // {sections:[{id,title,items:[{id,label,type,required,options?}]}]}
  version     Int            @default(1)
  isActive    Boolean        @default(true)
  price       Decimal?       @db.Decimal(12, 2) // үйлчилгээний үнэ — захиалгад нэмэх үед хэрэглэнэ
  durationMin Int?           // дундаж хугацаа (минут)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("DiagnosticTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports       DiagnosticReport[]
  plannedOrders OrderDiagnostic[]

  @@index([tenantId, type, isActive])
}

enum DiagnosticType {
  INTAKE
  POST_SERVICE
  ROUTINE
  DAMAGE_REPORT
}

// --- DiagnosticReport (бөглөгдсөн хуудас, захиалгад хавсаргана) -----------

model DiagnosticReport {
  id              String  @id @default(cuid())
  templateVersion Int
  data            Json    // {[itemId]: {value?, photos?, note?}}
  signatureUrl    String?
  mileageAtReport Int?
  notes           String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  templateId String
  template   DiagnosticTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  // Захиалгад хавсаргасан байж болно (заавал биш — мобайл дээр ширхэгээр үүсэх боломжтой)
  orderId String?
  order   ServiceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  filledById String?
  filledBy   User?   @relation("DiagnosticReportFilledBy", fields: [filledById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, orderId])
  @@index([vehicleId])
  @@index([customerId])
  @@index([branchId])
  @@index([templateId])
}

// --- OrderDiagnostic (захиалгад товлосон, бөглөгдөөгүй оношилгоо) ---------
// Захиалга үүсгэх үед оношилгоо нэмбэл энд бүртгэгдэнэ (бөглөхгүй). Захиалга
// эхэлсний дараа бөглөж DiagnosticReport үүсгэхэд тухайн мөр устгагдана.
model OrderDiagnostic {
  id String @id @default(cuid())

  orderId String
  order   ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  templateId String
  template   DiagnosticTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([orderId, templateId])
  @@index([orderId])
}

// --- LaborCategory (ажлын ангилал — зөвхөн LABOR төрлийн Service-д) ------

model LaborCategory {
  id          String  @id @default(cuid())
  name        String  // "Хөдөлгүүр", "Тоормос", "Цахилгаан", "Биеийн засвар" г.м.
  description String?
  isActive    Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

// --- Unit (хэмжих нэгж — ширхэг, цаг, литр, г.м.) -------------------------

model Unit {
  id       String  @id @default(cuid())
  name     String  // "ширхэг", "цаг", "литр", "кг", г.м.
  code     String? // богино тэмдэглэгээ — "ш", "ц", "л", "кг"
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services           Service[] @relation("ServiceUnit")
  servicesAsDuration Service[] @relation("ServiceDurationUnit")

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

// --- QPaySettings (платформын merchant — singleton) ----------------------

model QPaySettings {
  id                    Int       @id @default(1)
  username              String
  password              String
  invoiceCode           String
  callbackUrl           String?
  accessToken           String?
  refreshToken          String?
  tokenExpiresAt        DateTime?
  refreshTokenExpiresAt DateTime?
  updatedAt             DateTime  @updatedAt
}

// --- TenantQPaySettings (байгууллагын merchant — захиалгын төлбөрт) ------
// Тенант тус бүр өөрийн QPay merchant credentials оруулна. Захиалгын
// төлбөрийг үйлчлүүлэгчээс шууд авахын тулд ашиглана. Платформын
// `QPaySettings` нь зөвхөн subscription-д.

model TenantQPaySettings {
  id          String  @id @default(cuid())
  tenantId    String  @unique
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  username    String
  password    String  // TODO: production-д шифрлэх
  invoiceCode String
  callbackUrl String?

  enabled     Boolean @default(true)

  // Token кэш
  accessToken           String?
  refreshToken          String?
  tokenExpiresAt        DateTime?
  refreshTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- OrderPayment (захиалгын төлбөр — QPay invoice) ----------------------

enum OrderPaymentMethod {
  QPAY
  CASH
  BANK_TRANSFER
  OTHER
}

enum OrderPaymentStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

model OrderPayment {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderId String
  order   ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("MNT")

  method OrderPaymentMethod @default(QPAY)
  status OrderPaymentStatus @default(PENDING)

  // QPay-аас ирсэн талбарууд
  qpayInvoiceId String?
  qpayPaymentId String?
  qrImage       String? // base64
  qrText        String? // QPay deep link
  qpayUrls      Json?   // bank app deep links array
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([orderId])
  @@index([qpayInvoiceId])
}

// --- SubscriptionPayment (тенант төлбөр + QPay invoice) -----------------

enum SubscriptionPaymentMethod {
  QPAY
  BANK_TRANSFER
  CASH
  OTHER
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

model SubscriptionPayment {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Snapshot fields — PlanPrice устсан ч мэдээлэл хадгалагдана
  plan     Plan
  period   BillingPeriod
  amount   Decimal       @db.Decimal(12, 2)
  currency String        @default("MNT")

  planPriceId String?
  planPrice   PlanPrice? @relation(fields: [planPriceId], references: [id], onDelete: SetNull)

  method SubscriptionPaymentMethod @default(QPAY)
  status SubscriptionPaymentStatus @default(PENDING)

  // QPay-аас ирсэн талбарууд
  qpayInvoiceId String?
  qpayPaymentId String?
  qrImage       String? // base64 (data URL-руу хувиргаж харуулна)
  qrText        String? // deep link
  paidAt        DateTime?

  // PAID болсон үед энэ payment-аас үүссэн subscription
  createdSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([qpayInvoiceId])
}

// --- PlanPrice (super admin тогтоодог багц үнийн жагсаалт) ---------------

enum BillingPeriod {
  MONTH
  QUARTER
  YEAR
}

model PlanPrice {
  id        String        @id @default(cuid())
  plan      Plan
  period    BillingPeriod
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("MNT")
  isActive  Boolean       @default(true)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payments SubscriptionPayment[]

  @@unique([plan, period, currency])
  @@index([isActive])
}

// --- PlanFeature (багц бүрийн "юу багтсан" жагсаалт — super admin засварлана) -

model PlanFeature {
  id          String   @id @default(cuid())
  plan        Plan
  label       String   // "Хамгийн их хэрэглэгч"
  value       String   // "20", "Хязгааргүй", "Тийм", "—"
  description String?  // tooltip / урт тайлбар
  sortOrder   Int      @default(0)
  highlighted Boolean  @default(false) // pricing card-д тод харагдуулах
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([plan, sortOrder])
}

// --- PlanLimit (багц тус бүрийн машин шалгадаг хязгаар) -------------------
// `code` нь програмын дотор тогтсон key (max_users, daily_orders, ...).
// SuperAdmin зөвхөн тоон утга / boolean утгыг өөрчилнө. Кодын жагсаалт нь
// `lib/plan-limits.ts` дотор төвлөрсөн.

enum PlanLimitKind {
  COUNT   // тоон quota — intValue null бол хязгааргүй
  BOOLEAN // боломж нээх/хаах flag
}

model PlanLimit {
  id          String        @id @default(cuid())
  plan        Plan
  code        String        // ж: "max_users", "daily_orders"
  label       String        // дэлгэцэнд харуулах нэр
  description String?
  kind        PlanLimitKind @default(COUNT)
  intValue    Int?          // COUNT — null=хязгааргүй
  boolValue   Boolean?      // BOOLEAN
  sortOrder   Int           @default(0)
  highlighted Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plan, code])
  @@index([plan, sortOrder])
}

// --- Subscription (тенант бүрийн багц, түүх + 14 хоногийн trial) ---------

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

model Subscription {
  id     String             @id @default(cuid())
  plan   Plan
  status SubscriptionStatus

  startsAt DateTime
  endsAt   DateTime? // null бол байнгын/тогтоогдоогүй (paid no-expiry); TRIAL үед заавал

  amount      Decimal? @db.Decimal(12, 2) // төлсөн дүн (заавал биш)
  notes       String?
  cancelledAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // SuperAdmin гараар үүсгэсэн бол лавлана. Signup-аас үүсэх trial-д null.
  createdById String?
  createdBy   SuperAdmin? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([endsAt])
}

// --- OTP (6 оронтой нэг удаагийн код — signup, нууц үг шинэчлэх г.м.) ----

enum OtpType {
  SIGNUP
  CHANGE_PASSWORD
  RESET_PASSWORD
  CONSUMER_LOGIN // онлайн цаг захиалгын Account утсаар нэвтрэх
  SET_PASSWORD // ажилтны анхны нэвтрэлт — нууц үг үүсгэж аккаунт идэвхжүүлэх
}

model Otp {
  id         String   @id @default(cuid())
  // Хүлээн авагчийг email ЭСВЭЛ phone-оор холбоно. Ажилтан/тенантын урсгал
  // (SIGNUP/CHANGE/RESET) email-ээр, Account-ийн CONSUMER_LOGIN утсаар явна.
  email      String?
  phone      String?  // 8 оронтой канон формат (lib/phone.ts)
  codeHash   String   // зургаан оронтой код-н sha256 hex (раw код DB-д хадгалахгүй)
  type       OtpType
  attempts   Int      @default(0) // буруу баталгаажуулсан удаа

  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  // Тэмдэглэлүүд — аудит, "хэн илгээсэн" болон шинэ нууц үг боловсруулахдаа useful
  userId     String?  // байгаа хэрэглэгчийн change/reset үед бичнэ (signup-д null)
  accountId  String?  // CONSUMER_LOGIN — байгаа Account-д бичнэ (анхны нэвтрэлтэд null)
  ip         String?
  userAgent  String?

  @@index([email, type])
  @@index([phone, type])
  @@index([expiresAt])
  @@index([userId])
}

// --- Account (эцсийн хэрэглэгч — олон тенант хооронд цаг захиалагч) --------
// Тенантаас үл хамаарах global бүртгэл. Утсаар (OTP) нэвтэрнэ — нууц үггүй.
// Цаг захиалах үед тухайн тенантын [[Customer]]-той утсаар нь холбогдоно
// (Customer.accountId). User (ажилтан) болон SuperAdmin-аас тусдаа principal.
model Account {
  id        String  @id @default(cuid())
  phone     String  @unique // 8 оронтой канон формат (lib/phone.ts)
  name      String?
  email     String?
  avatarUrl String?
  isActive  Boolean @default(true) // false бол нэвтрэлт блоклогдоно

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customers    Customer[]
  appointments Appointment[]
  vehicles     AccountVehicle[]
  devices      Device[]
  notifications Notification[]
}

// --- AccountVehicle (хэрэглэгчийн global машин) ---------------------------
// Account-ийн өөрийн машинууд. Цаг захиалахад сонгоно; ажилтан баталгаажуулах
// үед тухайн тенантын [[Vehicle]] руу snapshot хийгдэнэ ([tenantId, plate]).
model AccountVehicle {
  id            String  @id @default(cuid())
  plate         String
  make          String
  model         String
  year          Int?
  vin           String?
  fuelType      String?
  wheelPosition String? // "Зүүн" / "Баруун" (HUR-аас)
  mileage       Int?

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@unique([accountId, plate])
  @@index([accountId])
}

// --- Appointment (онлайн цаг захиалгын хүсэлт) ----------------------------
// Account вэб/аппаас цаг хүсэхэд PENDING-ээр үүснэ. Ажилтан баталгаажуулахад
// тенантын [[Customer]]-той утсаар нь холбогдож (Customer.accountId), дараа нь
// одоо байгаа [[ServiceOrder]] урсгалаар бодит захиалга үүснэ.
enum AppointmentStatus {
  PENDING   // хэрэглэгч илгээсэн, ажилтан хариу өгөөгүй
  CONFIRMED // ажилтан баталгаажуулсан
  REJECTED  // ажилтан татгалзсан
  CANCELLED // хэрэглэгч цуцалсан
  NO_SHOW   // товлосон цагт ирээгүй
}

model Appointment {
  id          String            @id @default(cuid())
  status      AppointmentStatus @default(PENDING)
  requestedAt DateTime // хэрэглэгчийн хүссэн цаг
  note        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  // Онлайн захиалгад Account-той. Ажилтан утсаар бүртгэсэн (phone-in) бол null —
  // энэ тохиолдолд customerId-г шууд оноож, status CONFIRMED-ээр үүснэ.
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  // Онлайн: баталгаажуулах үед утсаар resolve хийгдэнэ. Phone-in: шууд оноогдоно.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Онлайн захиалгад хэрэглэгчийн сонгосон global машин (заавал биш).
  accountVehicleId String?
  accountVehicle   AccountVehicle? @relation(fields: [accountVehicleId], references: [id], onDelete: SetNull)

  // Баталгаажуулахад тенантын Vehicle руу snapshot хийгдсэн машин.
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  // Баталгаажсаны дараа үүсгэсэн захиалга (1:1).
  serviceOrderId String?       @unique
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  // Ажилтны хариу — хурдан унших талбарууд (дэлгэрэнгүй нь AuditLog-д).
  respondedAt   DateTime?
  respondedById String?

  // Сануулга SMS илгээсэн эсэх (cron давхар илгээхгүйн тулд).
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([branchId, requestedAt])
  @@index([accountId])
  @@index([status, requestedAt, reminderSentAt])
}

// --- RefreshToken (мобайл клиентэд зориулсан, эргүүлдэг token) -----------

model RefreshToken {
  id         String  @id @default(cuid())
  tokenHash  String  @unique // түүхий token-ы sha256 hex
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String? // rotation хэлхээ — энэ token-ийг ямар token орлоосон бэ
  userAgent    String?
  ip           String?

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// --- UserSession (ажилтны web нэвтрэлт — төхөөрөмж/түүх + revoke) --------
// Web cookie session-ийг DB-д хөтөлж, "нэвтэрсэн төхөөрөмжүүд"-ийг харах,
// тус бүрийг алсаас "гаргах" (revoke) боломжтой болгоно. JWT-д session id (sid)
// шигтгэж, getSession бүрт энэ бичлэгийг шалгана.
model UserSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ip        String?

  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// --- Device (web/мобайл төхөөрөмж — push notification-д) -----------------
// FCM (firebase) token + төхөөрөмжийн мета. Эзэн нь User (ажилтан) ЭСВЭЛ
// Account (хэрэглэгч). Клиент `deviceId`-аар upsert хийж, нэвтрэх бүрт эзнийг
// шинэчилнэ (нэг install дээр өөр хэрэглэгч нэвтэрвэл эзэн дамждаг).
enum DevicePlatform {
  WEB
  ANDROID
  IOS
}

model Device {
  id            String         @id @default(cuid())
  deviceId      String         @unique // клиентийн үүсгэсэн install id
  platform      DevicePlatform
  firebaseToken String? // FCM push token
  name          String? // "Bat's iPhone"
  model         String? // "iPhone 14 Pro" / "SM-G991B"
  os            String? // "iOS 17.2" / "Android 14" / "Windows"

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([firebaseToken])
}

// --- Notification (мэдэгдэлийн төв + түүх — ажилтан ба Account хоёуланд) ----
// Илгээгдсэн push мэдэгдэл бүрийг хадгална. Эзэн нь User (ажилтан) ЭСВЭЛ Account
// (хэрэглэгч) — `Device` model шиг яг нэг нь утгатай (XOR check constraint-аар
// баталгаажна). Уншаагүй тоо/жагсаалт/түүхэнд ашиглана. Шинэ мэдэгдэл нь хүлээн
// авагч тус бүрд нэг мөр (fan-out) болж үүснэ.
model Notification {
  id String @id @default(cuid())

  // Ажилтны мөрд тенант/салбарын context (cleanup, шүүлтэд). Account-д null.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Хүлээн авагч — яг нэг нь утгатай (migration дахь XOR check constraint).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type  String // registry key — "appointment_confirmed", "appointment_created" г.м.
  title String
  body  String
  data  Json? // deep-link бүтээхэд — { appointmentId, orderId, ... }

  // Идемпотент event-д давхар үүсэхээс сэргийлнэ ("type:appointmentId"). Бусдад null.
  dedupeKey String? @unique

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([accountId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
}

// --- PlatformSetting (нэг мөртэй global тохиргоо — SuperAdmin засна) ------
// Landing/footer-т харагдах сошиал холбоос г.м. Нэг л мөр (id="default").
model PlatformSetting {
  id          String   @id @default("default")
  facebookUrl String?
  youtubeUrl  String?
  updatedAt   DateTime @updatedAt
}

// --- SuperAdmin (carcare.mn-ын платформын эзэн) ---------------------------

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String
  lastName     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptionsCreated Subscription[]
}

// --- AuditLog (тенант доторх чухал үйлдлийн түүх) ------------------------
// Захиалгын статус өөрчлөлт, барааны нөөц хөдөлгөөн, мөр нэмэх/устгах
// зэрэг чухал үйлдлүүдийг бичнэ. `entity`/`entityId` нь полиморф холбоос
// — тус бүр Prisma relation үүсгэхгүй (хэт ихсэх тул). `summary` нь хүний
// уншимтгай нэг мөр, `before`/`after` нь сонгосон талбаруудын snapshot.

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  PAYMENT_CHANGE
  STOCK_CHANGE
  ITEM_ADDED
  ITEM_REMOVED
  ITEM_UPDATED
  LOGIN
  LOGOUT
  OTHER
}

model AuditLog {
  id       String      @id @default(cuid())
  entity   String      // "ServiceOrder", "Service", "Customer", "Vehicle", "User", "Branch"
  entityId String
  action   AuditAction
  summary  String?     // "SCHEDULED → IN_PROGRESS", "Stock decremented by 5 ш"
  before   Json?
  after    Json?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("AuditLogActor", fields: [userId], references: [id], onDelete: SetNull)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, action, createdAt])
  @@index([userId])
}
