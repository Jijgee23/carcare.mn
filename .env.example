PORT=3001

# PostgreSQL connection. Жишээ: postgresql://USER:PASS@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/carcare.mn?schema=public"

# pg pool-ийн нэгэн зэрэг холболтын дээд хязгаар. Заавал биш —
# Vercel/serverless дээр 1, бусад дээр 10 (default). PgBouncer-ийн ард эсвэл
# тусгай тохируулга хэрэгтэй бол энд override хийнэ.
# DATABASE_POOL_MAX=1

# `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"` ажиллуулж шинэ утга үүсгээрэй.
SESSION_SECRET="дор хаяж 32 тэмдэгт-аас урт санамсаргүй мөр"

# DB дахь эмзэг утгыг (QPay merchant нууц үг, token) шифрлэх түлхүүр (AES-256-GCM).
# Заавал биш — тохируулаагүй бол SESSION_SECRET-г ашиглана. Тусд нь ротаци хийх
# боломжтой болгохын тулд production-д тусгай утга өгөхийг зөвлөнө.
ENCRYPTION_KEY="дор хаяж 32 тэмдэгт санамсаргүй мөр"

# Cron job-н Bearer secret. Vercel Cron / гадуурх scheduler-аас
# /api/cron/expire-subscriptions-руу дуудахдаа `Authorization: Bearer <secret>`
# эсвэл `?secret=<secret>` query-аар илгээнэ.
CRON_SECRET="дор хаяж 32 тэмдэгт санамсаргүй мөр"

# HUR (МАК-ын vehicle registry) API.
# Машин бүртгэхэд улсын дугаараар автомат мэдээлэл татахад ашиглана.
HUR_URL="https://hur.api.macs.mn/"
HUR_USERNAME=""
HUR_PASSWORD=""
HUR_CODE=""
